<Window x:Class="AppTunnel.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="App Tunnel"
        Width="1320"
        Height="860"
        MinWidth="1100"
        MinHeight="760"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextStrongBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        </Style>
        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="18,8" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceMutedBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="26"
                Padding="24"
                BorderBrush="{StaticResource AccentSoftBrush}"
                BorderThickness="1"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A2230" Offset="0" />
                    <GradientStop Color="#FF111827" Offset="0.6" />
                    <GradientStop Color="#FF241A16" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift SemiCondensed"
                               FontSize="40"
                               FontWeight="SemiBold"
                               Text="App Tunnel" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyStyle}"
                               FontSize="16"
                               Text="Initial scaffold for app-scoped tunnel profiles, dry-run routing, named-pipe IPC, DPAPI secret storage, and structured diagnostics." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Text="Service connection" />
                    <TextBlock FontFamily="Bahnschrift SemiCondensed"
                               FontSize="24"
                               Text="{Binding ServiceStatus}" />
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Text="{Binding ServiceRunState}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="Refresh"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshCommand}" />
                        <Button Content="Export Logs"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="12,0,0,0"
                                Command="{Binding ExportLogsCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource AccentSoftBrush}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Service Boundary" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Protocol version" />
                                    <TextBlock FontSize="18" Text="{Binding ProtocolVersion}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last handshake" />
                                    <TextBlock FontSize="18" Text="{Binding LastHandshakeUtc}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last error" />
                                    <TextBlock FontSize="16" Text="{Binding LastError}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Runtime Summary" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Started at" />
                                    <TextBlock FontSize="18" Text="{Binding StartedAtUtc}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Profiles" />
                                    <TextBlock FontSize="18" Text="{Binding LoadedProfilesSummary}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="App rules" />
                                    <TextBlock FontSize="18" Text="{Binding LoadedRulesSummary}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Preferred routing backend" />
                                    <TextBlock FontSize="18" Text="{Binding PreferredRoutingBackend}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Registered Tunnel Engines" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding TunnelEngines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Dry-Run Managers" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Tunnel manager" />
                                    <TextBlock FontSize="16" Text="{Binding TunnelManagerState}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Router manager" />
                                    <TextBlock FontSize="16" Text="{Binding RouterManagerState}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Registered Routing Backends" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding RouterBackends}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Known Gaps" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding KnownGaps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profiles">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Margin="0,0,0,12"
                               Text="Profiles are loaded by the service from the persisted JSON scaffold configuration." />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Profiles}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" />
                            <DataGridTextColumn Header="Tunnel" Binding="{Binding TunnelKind}" Width="*" />
                            <DataGridTextColumn Header="Config Path" Binding="{Binding ImportedConfigPath}" Width="3*" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="*" />
                            <DataGridTextColumn Header="Imported" Binding="{Binding ImportedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Apps">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Margin="0,0,0,12"
                               Text="App rules define which executable path is assigned to which tunnel profile in dry-run mode." />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AppRules}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" />
                            <DataGridTextColumn Header="Executable Path" Binding="{Binding ExecutablePath}" Width="3*" />
                            <DataGridTextColumn Header="Profile ID" Binding="{Binding ProfileId}" Width="2*" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="*" />
                            <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource BodyStyle}"
                                   Text="Structured log entries are written by the service to JSON-lines files and can be exported as a support bundle." />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyStyle}"
                                   Text="{Binding LastExportPath}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentLogs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="2*" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="*" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="IPC" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Style="{StaticResource BodyStyle}" Text="Named pipe" />
                                <TextBlock FontSize="16" Text="{Binding PipeName}" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Refresh interval (seconds)" />
                                <TextBlock FontSize="16" Text="{Binding RefreshIntervalSeconds}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Storage" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Style="{StaticResource BodyStyle}" Text="Root directory" />
                                <TextBlock FontSize="16" Text="{Binding DataRootDirectory}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Configuration file" />
                                <TextBlock FontSize="16" Text="{Binding ConfigurationFilePath}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Logs directory" />
                                <TextBlock FontSize="16" Text="{Binding LogsDirectory}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Exports directory" />
                                <TextBlock FontSize="16" Text="{Binding ExportsDirectory}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
