<Window x:Class="AppTunnel.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="App Tunnel"
        Width="1220"
        Height="780"
        MinWidth="980"
        MinHeight="680"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextStrongBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        </Style>
        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,14,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="28"
                Padding="28"
                BorderBrush="{StaticResource AccentSoftBrush}"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A2230" Offset="0" />
                    <GradientStop Color="#FF111827" Offset="0.6" />
                    <GradientStop Color="#FF241A16" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift SemiCondensed"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Text="App Tunnel" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyStyle}"
                               FontSize="16"
                               Text="Windows-only app-scoped VPN routing scaffold with a WPF shell, Windows service broker, named pipes, DPAPI, and pluggable routing backends." />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Handshake" Style="{StaticResource BodyStyle}" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding ServiceStatus}"
                               FontSize="22"
                               FontFamily="Bahnschrift SemiCondensed"
                               HorizontalAlignment="Right" />
                    <Button Content="Refresh Service State"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Service Boundary" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Style="{StaticResource BodyStyle}" Text="Protocol version" />
                    <TextBlock FontSize="18" Text="{Binding ProtocolVersion}" />
                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last handshake" />
                    <TextBlock FontSize="18" Text="{Binding LastHandshakeUtc}" />
                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last error" />
                    <TextBlock FontSize="16" Text="{Binding LastError}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Current Mode" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Style="{StaticResource BodyStyle}" Text="Distribution mode" />
                    <TextBlock FontSize="18" Text="{Binding DistributionMode}" />
                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Preferred router" />
                    <TextBlock FontSize="18" Text="{Binding PreferredRouter}" />
                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Current UI scope" />
                    <TextBlock FontSize="16" Text="Win32 .exe assignment now, packaged Windows apps later." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Inputs" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Style="{StaticResource BodyStyle}" Text="Supported app kinds" />
                            <ItemsControl ItemsSource="{Binding SupportedAppKinds}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,6" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource BodyStyle}" Text="Planned app kinds" />
                            <ItemsControl ItemsSource="{Binding PlannedAppKinds}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,6" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource BodyStyle}" Text="Supported profile kinds" />
                            <ItemsControl ItemsSource="{Binding SupportedProfileKinds}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,6" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource BodyStyle}" Text="Planned profile kinds" />
                            <ItemsControl ItemsSource="{Binding PlannedProfileKinds}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,6" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Tunnel Engines" Style="{StaticResource SectionHeaderStyle}" />
                            <ItemsControl ItemsSource="{Binding TunnelEngines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Routing Backends" Style="{StaticResource SectionHeaderStyle}" />
                            <ItemsControl ItemsSource="{Binding RouterBackends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Known Gaps" Style="{StaticResource SectionHeaderStyle}" />
                            <ItemsControl ItemsSource="{Binding KnownGaps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
