<Window x:Class="AppTunnel.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="App Tunnel"
        Width="1320"
        Height="860"
        MinWidth="1100"
        MinHeight="760"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextStrongBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        </Style>
        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="18,8" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceMutedBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="26"
                Padding="24"
                BorderBrush="{StaticResource AccentSoftBrush}"
                BorderThickness="1"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A2230" Offset="0" />
                    <GradientStop Color="#FF111827" Offset="0.6" />
                    <GradientStop Color="#FF241A16" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift SemiCondensed"
                               FontSize="40"
                               FontWeight="SemiBold"
                               Text="App Tunnel" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyStyle}"
                               FontSize="16"
                               Text="Control surface for importing WireGuard and OpenVPN profiles, protecting tunnel material with DPAPI, and managing service-owned tunnel lifecycle on Windows." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Text="Service connection" />
                    <TextBlock FontFamily="Bahnschrift SemiCondensed"
                               FontSize="24"
                               Text="{Binding ServiceStatus}" />
                    <TextBlock Style="{StaticResource BodyStyle}"
                               Text="{Binding ServiceRunState}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="Import WireGuard"
                              Style="{StaticResource ActionButtonStyle}"
                              Command="{Binding ImportWireGuardProfileCommand}" />
                        <Button Content="Import OpenVPN"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="12,0,0,0"
                                Command="{Binding ImportOpenVpnProfileCommand}" />
                        <Button Content="Refresh"
                                Style="{StaticResource ActionButtonStyle}"
                              Margin="12,0,0,0"
                              Command="{Binding RefreshCommand}" />
                        <Button Content="Export Logs"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="12,0,0,0"
                                Command="{Binding ExportLogsCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource AccentSoftBrush}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Service Boundary" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Protocol version" />
                                    <TextBlock FontSize="18" Text="{Binding ProtocolVersion}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last handshake" />
                                    <TextBlock FontSize="18" Text="{Binding LastHandshakeUtc}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Last error" />
                                    <TextBlock FontSize="16" Text="{Binding LastError}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Runtime Summary" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Started at" />
                                    <TextBlock FontSize="18" Text="{Binding StartedAtUtc}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Profiles" />
                                    <TextBlock FontSize="18" Text="{Binding LoadedProfilesSummary}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="App rules" />
                                    <TextBlock FontSize="18" Text="{Binding LoadedRulesSummary}" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Preferred routing backend" />
                                    <TextBlock FontSize="18" Text="{Binding PreferredRoutingBackend}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Registered Tunnel Engines" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding TunnelEngines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Routing Diagnostics" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Tunnel manager" />
                                    <TextBlock FontSize="16" Text="{Binding TunnelManagerState}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Router manager" />
                                    <TextBlock FontSize="16" Text="{Binding RouterManagerState}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Active tunnel" />
                                    <TextBlock FontSize="16" Text="{Binding DiagnosticsActiveTunnel}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Elevation" />
                                    <TextBlock FontSize="16" Text="{Binding DiagnosticsElevation}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Registered Routing Backends" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding RouterBackends}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="WinDivert Activity" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Selected processes" />
                                    <ItemsControl ItemsSource="{Binding SelectedProcessDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Mapped flows" />
                                    <ItemsControl ItemsSource="{Binding MappedFlowDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Dropped packets" />
                                    <ItemsControl ItemsSource="{Binding DroppedPacketDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Error states" />
                                    <ItemsControl ItemsSource="{Binding ErrorStateDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Known Gaps" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding KnownGaps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,8" Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profiles">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource BodyStyle}"
                                   Text="Import WireGuard .conf files or OpenVPN .ovpn files. The service stores metadata in app configuration and protects credentials plus tunnel material with DPAPI." />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyStyle}"
                                   Text="{Binding ProfileActionMessage}" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Imported Profiles" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Select a profile to inspect parsed details and current tunnel state." />
                                </StackPanel>

                                <ListView Grid.Row="1"
                                          Margin="0,16,0,0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                                                    Padding="16"
                                                    Background="{StaticResource SurfaceMutedBrush}"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   FontFamily="{StaticResource HeadingFont}"
                                                                   FontSize="20"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Text="{Binding ConnectionState}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource BodyStyle}"
                                                               Text="{Binding ConnectionSummary}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Style="{StaticResource BodyStyle}"
                                                                 Text="{Binding ListSummary}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource BodyStyle}"
                                                               Text="{Binding BackendName}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedProfile.DisplayName, TargetNullValue=No profile selected}"
                                               Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}"
                                               Text="{Binding SelectedProfile.ConnectionSummary, TargetNullValue=Import a tunnel profile to view details.}" />

                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="Connect"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding ConnectProfileCommand}" />
                                        <Button Content="Disconnect"
                                                Style="{StaticResource ShellGhostButtonStyle}"
                                                Margin="12,0,0,0"
                                                Command="{Binding DisconnectProfileCommand}" />
                                    </StackPanel>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Live status" />
                                            <TextBlock FontSize="18"
                                                       Text="{Binding SelectedProfile.ConnectionState, TargetNullValue=Unavailable}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedProfile.BackendName, TargetNullValue=Unavailable}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedProfile.LastStatusUpdateUtc, StringFormat=Updated {0}, TargetNullValue=Unavailable}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedProfile.ErrorMessage, StringFormat=Error: {0}, TargetNullValue=None}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Profile details" />
                                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedProfile.Details}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Style="{StaticResource BodyStyle}" Text="{Binding Label}" />
                                                            <TextBlock FontSize="16"
                                                                       Text="{Binding Value}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Import validation" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedProfile.ValidationSummary, TargetNullValue=Validation details unavailable.}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Recent tunnel logs" />
                                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedProfileLogs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,8"
                                                                   FontSize="14"
                                                                   Text="{Binding}"
                                                                   TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Apps">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Text="Win32 rules store normalized executable paths now and reserve packaged-app identity fields for future discovery." />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyStyle}"
                                       Text="{Binding AppActionMessage}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Add Win32 App"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding AddAppRuleCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Apps List" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource BodyStyle}" Text="Each rule targets one app identity and stores assignment behavior even before live routing enforcement exists." />
                                </StackPanel>

                                <ListView Grid.Row="1"
                                          Margin="0,16,0,0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ItemsSource="{Binding AppRules}"
                                          SelectedItem="{Binding SelectedAppRule}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                                                    Padding="16"
                                                    Background="{StaticResource SurfaceMutedBrush}"
                                                    CornerRadius="16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="56"
                                                            Height="56"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            CornerRadius="16">
                                                        <Grid>
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="{StaticResource HeadingFont}"
                                                                       FontSize="22"
                                                                       Text="{Binding IconMonogram}" />
                                                            <Image Width="28"
                                                                   Height="28"
                                                                   Stretch="Uniform"
                                                                   Source="{Binding IconSource}" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                                   FontSize="20"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource BodyStyle}"
                                                                   Text="{Binding TargetSummary}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Style="{StaticResource BodyStyle}"
                                                                   Text="{Binding AssignedProfileDisplayName, StringFormat=Assigned to {0}}" />
                                                    </StackPanel>

                                                    <Border Grid.Column="3"
                                                            Padding="10,4"
                                                            CornerRadius="999"
                                                            Background="{Binding StatusBadgeBrush}">
                                                        <TextBlock Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding StatusBadgeText}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding SelectedAppRule.DisplayName, TargetNullValue=No app selected}"
                                                       Style="{StaticResource SectionHeaderStyle}" />
                                            <TextBlock Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedAppRule.StatusSummary, TargetNullValue=Add a Win32 .exe to create a new rule target.}" />
                                        </StackPanel>
                                        <Border DockPanel.Dock="Right"
                                                Padding="10,4"
                                                CornerRadius="999"
                                                Background="{Binding SelectedAppRule.StatusBadgeBrush}"
                                                Margin="12,0,0,0">
                                            <TextBlock Foreground="White"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedAppRule.StatusBadgeText, TargetNullValue=Idle}" />
                                        </Border>
                                    </DockPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="Assign Profile"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding AssignAppRuleCommand}" />
                                    </StackPanel>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="74"
                                                    Height="74"
                                                    Background="{StaticResource SurfaceBrush}"
                                                    CornerRadius="20">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{StaticResource HeadingFont}"
                                                               FontSize="30"
                                                               Text="{Binding SelectedAppRule.IconMonogram, TargetNullValue=A}" />
                                                    <Image Width="36"
                                                           Height="36"
                                                           Stretch="Uniform"
                                                           Source="{Binding SelectedAppRule.IconSource}" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource BodyStyle}" Text="App target" />
                                                <TextBlock FontSize="16"
                                                           Text="{Binding SelectedAppRule.AppKindLabel, TargetNullValue=Unavailable}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Style="{StaticResource BodyStyle}"
                                                           Text="{Binding SelectedAppRule.TargetSummary, TargetNullValue=Unavailable}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Assignment" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.AssignedProfileDisplayName, TargetNullValue=Unassigned}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedAppRule.StatusSummary, TargetNullValue=No rule selected.}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Style="{StaticResource BodyStyle}"
                                                       Text="{Binding SelectedAppRule.UpdatedAtUtc, StringFormat=Updated {0}, TargetNullValue=Unavailable}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Rule settings" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.IsEnabled, StringFormat=Enabled: {0}, TargetNullValue=Enabled: False}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.LaunchOnConnect, StringFormat=Launch on connect: {0}, TargetNullValue=Launch on connect: False}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.KillAppTrafficOnTunnelDrop, StringFormat=Kill app traffic on tunnel drop: {0}, TargetNullValue=Kill app traffic on tunnel drop: False}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.IncludeChildProcesses, StringFormat=Include child processes: {0}, TargetNullValue=Include child processes: False}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource BodyStyle}" Text="Future packaged-app identity fields" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.PackageFamilyName, StringFormat=Package family: {0}, TargetNullValue=Package family: Unavailable}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedAppRule.PackageIdentity, StringFormat=Package identity: {0}, TargetNullValue=Package identity: Unavailable}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource BodyStyle}"
                                   Text="Structured log entries are written by the service to JSON-lines files and can be exported as a support bundle." />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyStyle}"
                                   Text="{Binding LastExportPath}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentLogs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="2*" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="*" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Routing Backend" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Style="{StaticResource BodyStyle}" Text="Choose which routing backend the service should enforce for selected apps." />
                                <ComboBox Margin="0,12,0,0"
                                          ItemsSource="{Binding AvailableRoutingBackends}"
                                          SelectedItem="{Binding SelectedRoutingBackend}" />
                                <Button Margin="0,12,0,0"
                                        Content="Apply Routing Backend"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ApplyRoutingBackendCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="IPC" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Style="{StaticResource BodyStyle}" Text="Named pipe" />
                                <TextBlock FontSize="16" Text="{Binding PipeName}" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Refresh interval (seconds)" />
                                <TextBlock FontSize="16" Text="{Binding RefreshIntervalSeconds}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Storage" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Style="{StaticResource BodyStyle}" Text="Root directory" />
                                <TextBlock FontSize="16" Text="{Binding DataRootDirectory}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Configuration file" />
                                <TextBlock FontSize="16" Text="{Binding ConfigurationFilePath}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Logs directory" />
                                <TextBlock FontSize="16" Text="{Binding LogsDirectory}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0" Style="{StaticResource BodyStyle}" Text="Exports directory" />
                                <TextBlock FontSize="16" Text="{Binding ExportsDirectory}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
