<Window x:Class="AppTunnel.UI.Views.AddAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Win32 App"
        Width="720"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextStrongBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource ShellTitleStyle}" Text="Add Win32 App" />
            <TextBlock Style="{StaticResource ShellBodyStyle}" Text="Browse for an .exe to create a future rule target. Packaged-app discovery is reserved for a later pass." />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource ShellCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="88"
                        Height="88"
                        VerticalAlignment="Top"
                        Background="{StaticResource SurfaceMutedBrush}"
                        CornerRadius="22">
                    <Grid>
                        <Image x:Name="IconPreview" Width="40" Height="40" Stretch="Uniform" />
                        <TextBlock x:Name="FallbackMonogram"
                                   FontFamily="{StaticResource HeadingFont}"
                                   FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="A" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ShellBodyStyle}" Text="Executable" />
                    <DockPanel Margin="0,8,0,0">
                        <Button Content="Browse"
                                DockPanel.Dock="Right"
                                Margin="12,0,0,0"
                                Style="{StaticResource ShellGhostButtonStyle}"
                                Click="BrowseButtonOnClick" />
                        <TextBox x:Name="ExecutablePathTextBox"
                                 MinWidth="420"
                                 Padding="12,8"
                                 Background="{StaticResource SurfaceMutedBrush}"
                                 BorderBrush="{StaticResource AccentSoftBrush}"
                                 Foreground="{StaticResource TextStrongBrush}"
                                 TextChanged="ExecutablePathTextBoxOnTextChanged" />
                    </DockPanel>

                    <TextBlock Margin="0,18,0,0" Style="{StaticResource ShellBodyStyle}" Text="Display name" />
                    <TextBox x:Name="DisplayNameTextBox"
                             Margin="0,8,0,0"
                             Padding="12,8"
                             Background="{StaticResource SurfaceMutedBrush}"
                             BorderBrush="{StaticResource AccentSoftBrush}"
                             Foreground="{StaticResource TextStrongBrush}" />

                    <TextBlock Margin="0,18,0,0"
                               Style="{StaticResource ShellBodyStyle}"
                               Text="The service will normalize the path to an absolute executable path before storing the rule." />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource ShellGhostButtonStyle}"
                    Click="CancelButtonOnClick" />
            <Button Content="Add App"
                    Margin="12,0,0,0"
                    Style="{StaticResource ShellAccentButtonStyle}"
                    Click="AddButtonOnClick" />
        </StackPanel>
    </Grid>
</Window>