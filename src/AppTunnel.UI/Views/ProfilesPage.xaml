<UserControl x:Class="AppTunnel.UI.Views.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource ShellCardStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource ShellTitleStyle}" Text="Tunnel Profiles" />
                <TextBlock Style="{StaticResource ShellBodyStyle}" Text="Imported profiles currently visible to the service." />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource ShellCardStyle}">
            <ListView ItemsSource="{Binding Profiles}" Background="Transparent" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="16" Background="{StaticResource SurfaceMutedBrush}" CornerRadius="16">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource HeadingFont}" FontSize="19" Text="{Binding DisplayName}" />
                                <TextBlock Style="{StaticResource ShellBodyStyle}" Text="{Binding TunnelKind}" />
                                <TextBlock Style="{StaticResource ShellBodyStyle}" Text="{Binding ImportedConfigPath}" />
                                <TextBlock Style="{StaticResource ShellBodyStyle}" Text="{Binding ConnectionState}" />
                                <TextBlock Style="{StaticResource ShellBodyStyle}" Text="{Binding ImportedAtUtc, StringFormat=Imported {0}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>
